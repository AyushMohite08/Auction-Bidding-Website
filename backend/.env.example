# Backend Environment Variables

# Database Configuration
RDS_HOST=localhost
RDS_USER=root
RDS_PASS=your_database_password_here
RDS_DB=auction_db
RDS_PORT=3306
# DB pool tuning. Lower defaults are friendlier for local/free-tier deployment.
DB_CONNECTION_LIMIT=5
DB_MAX_IDLE_CONNECTIONS=2
DB_IDLE_TIMEOUT_MS=60000
# Enable for TiDB Cloud/hosted MySQL public connections that require TLS.
DB_SSL_ENABLED=false
DB_SSL_REJECT_UNAUTHORIZED=true
# Render usually needs 1 because it runs behind a reverse proxy. Keep 0 locally.
TRUST_PROXY_HOPS=0

# JWT Secrets (use different long random values for access and refresh)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# JWT_SECRET is only a fallback. Prefer setting JWT_ACCESS_SECRET and JWT_REFRESH_SECRET.
# JWT_SECRET=your_legacy_fallback_secret_here
JWT_ACCESS_SECRET=your_long_random_access_secret_here
JWT_REFRESH_SECRET=your_different_long_random_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Auth Cookies
AUTH_ACCESS_COOKIE_NAME=auction_access
AUTH_REFRESH_COOKIE_NAME=auction_refresh
AUTH_ACCESS_COOKIE_MAX_AGE_MS=900000
AUTH_REFRESH_COOKIE_MAX_AGE_MS=604800000

# Same-site/local HTTP setup:
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=.yourdomain.com

# Cross-site HTTPS setup, for different frontend/backend sites:
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_DOMAIN=.yourdomain.com

# Server Configuration
PORT=3000
NODE_ENV=development  # Change to 'production' in production environment

# Maintenance mode (pause API), when db limit is up and we need to temporarily stop accepting requests
API_PAUSED=false
API_PAUSED_MESSAGE=Service temporarily unavailable. Please try again later.

# CORS (comma-separated for multiple deployed frontend domains)
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173

# Auction image uploads
MAX_AUCTION_IMAGE_SIZE_MB=5

# ImageKit auction image uploads
IMAGEKIT_PRIVATE_KEY=private_your_imagekit_private_key
IMAGEKIT_PUBLIC_KEY=public_your_imagekit_public_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_UPLOAD_FOLDER=/auction-items

# Socket.IO diagnostics (only enable in development or if you need to debug)
SOCKET_DEBUG=false

# Basic rate limits and vendor quota
# General API limit per IP per 15 minutes.
RATE_LIMIT_GENERAL_MAX=600
# Failed login limit per IP + role + email per 15 minutes.
RATE_LIMIT_AUTH_MAX=5
# Registration limit per IP per hour.
RATE_LIMIT_REGISTER_MAX=5
# Bid limit per logged-in customer per 5 minutes.
RATE_LIMIT_BID_MAX=30
# Auction creation attempts per logged-in vendor per hour.
RATE_LIMIT_AUCTION_CREATE_MAX=10
# Created auctions per vendor per database calendar month. All statuses count.
VENDOR_MONTHLY_AUCTION_LIMIT=20

