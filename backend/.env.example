# Backend Environment Variables

# Database Configuration
RDS_HOST=localhost
RDS_USER=root
RDS_PASS=your_database_password_here
RDS_DB=auction_db
RDS_PORT=3306

# JWT Secrets (change these to long random strings)
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_ACCESS_SECRET=your_access_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_jwt_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Auth Cookies
AUTH_ACCESS_COOKIE_NAME=auction_access
AUTH_REFRESH_COOKIE_NAME=auction_refresh
AUTH_ACCESS_COOKIE_MAX_AGE_MS=900000
AUTH_REFRESH_COOKIE_MAX_AGE_MS=604800000

# Same-site/local HTTP setup:
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=.yourdomain.com

# Cross-site HTTPS setup, for different frontend/backend sites:
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_DOMAIN=.yourdomain.com

# Server Configuration
PORT=3000
NODE_ENV=development
API_PAUSED=false
API_PAUSED_MESSAGE=Service temporarily unavailable. Please try again later.

# CORS (comma-separated for multiple deployed frontend domains)
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173

# Auction image uploads
MAX_AUCTION_IMAGE_SIZE_MB=5

# ImageKit auction image uploads
IMAGEKIT_PRIVATE_KEY=private_your_imagekit_private_key
IMAGEKIT_PUBLIC_KEY=public_your_imagekit_public_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_UPLOAD_FOLDER=/auction-items

# Socket.IO diagnostics
SOCKET_DEBUG=false

# Basic rate limits and vendor quota
RATE_LIMIT_GENERAL_MAX=600
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_BID_MAX=30
RATE_LIMIT_AUCTION_CREATE_MAX=10
VENDOR_MONTHLY_AUCTION_LIMIT=20
